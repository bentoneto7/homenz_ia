# ──────────────────────────────────────────────────────────────────────────────
# Homenz.ia — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ──────────────────────────────────────────────────────────────────────────────

# ── Banco de dados ────────────────────────────────────────────────────────────
# MySQL/TiDB (obrigatório para o backend)
DATABASE_URL=mysql://user:password@host:3306/homenz

# ── Autenticação JWT ──────────────────────────────────────────────────────────
JWT_SECRET=troque-por-uma-string-aleatoria-segura

# ── OpenAI / IA ───────────────────────────────────────────────────────────────
# Chave da OpenAI (para chat IA, análise capilar e geração de imagem)
OPENAI_API_KEY=sk-...
# URL base customizada (opcional — use se tiver um proxy ou outro provider compatível)
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Storage de arquivos ───────────────────────────────────────────────────────
# Opção A: AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=homenz-uploads

# Opção B: Supabase Storage (alternativo ao S3)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=homenz

# ── Supabase (banco de dados alternativo / auth) ──────────────────────────────
# Usado pelo supabase.ts e supabaseMigration.ts
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (pagamentos) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# ── Brevo (e-mail transacional) ───────────────────────────────────────────────
BREVO_API_KEY=

# ── Meta CAPI (rastreamento de conversões) ────────────────────────────────────
# META_PIXEL_ID=
# META_ACCESS_TOKEN=

# ── Notificações (opcional) ───────────────────────────────────────────────────
# URL de webhook para notificações ao owner (ex: Slack, Discord, n8n)
# NOTIFICATION_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Analytics (opcional) ─────────────────────────────────────────────────────
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=

# ── Ambiente ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
